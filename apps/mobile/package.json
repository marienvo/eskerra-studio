    "storybook:android": "WITH_STORYBOOK=1 ENTRY_FILE=index.storybook.js react-native run-android",
    "test": "jest",
    "test:scripts": "node --test ../../scripts/bump-release-version-lib.test.mjs ../../scripts/sync-app-version-artifacts-lib.test.mjs"
  },
