{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "eskerra",
  "mainBinaryName": "eskerra",
  "version": "../../mobile/package.json",
  "identifier": "com.eskerra.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "enableGTKAppId": true,
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Eskerra",
        "width": 640,
        "height": 400,
        "minWidth": 520,
        "minHeight": 380,
        "resizable": true,
        "visible": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCONFIG/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$DATA/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$HOME/**",
          "$PICTURE/**",
          "$PUBLIC/**",
          "/media/**",
          "/mnt/**",
          "/run/media/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Eskerra",
    "homepage": "https://github.com/marienvo/notebox",
    "license": "AGPL-3.0-only",
    "category": "Productivity",
    "shortDescription": "Desktop companion for your local Eskerra vault — notes, podcasts, and playback.",
    "longDescription": "Eskerra opens a folder-based vault on your machine: markdown in Inbox, podcast notes from General, and MP3 streaming with playlist state. On Fedora and GNOME, playback integrates with the shell via MPRIS (media keys and system controls). RSS sync and some mobile-only accelerations are not required for this desktop release; the vault layout stays compatible with the Android app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "rpm": {
        "desktopTemplate": "linux/eskerra.desktop.hbs",
        "postInstallScript": "linux/rpm-postinstall.sh",
        "preRemoveScript": "linux/rpm-preremove.sh",
        "files": {
          "/usr/bin/eskerra-reminderd": "../../../target/release/eskerra-reminderd",
          "/usr/lib/systemd/user/eskerra-reminderd.service": "linux/eskerra-reminderd.service",
          "/usr/lib/systemd/user-preset/80-eskerra-reminderd.preset": "linux/80-eskerra-reminderd.preset",
          "/usr/share/applications/com.eskerra.desktop.desktop": "linux/com.eskerra.desktop.desktop",
          "/usr/share/icons/hicolor/32x32/apps/com.eskerra.desktop.png": "icons/32x32.png",
          "/usr/share/icons/hicolor/64x64/apps/com.eskerra.desktop.png": "icons/64x64.png",
          "/usr/share/icons/hicolor/128x128/apps/com.eskerra.desktop.png": "icons/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/com.eskerra.desktop.png": "icons/128x128@2x.png",
          "/usr/share/metainfo/eskerra.metainfo.xml": "metainfo/eskerra.metainfo.xml",
          "/usr/share/eskerra/screenshot.png": "../../../assets/screenshot.png"
        }
      }
    }
  }
}
